# ==========================================
# 1. 공통 환경 설정 및 범용 무시
# ==========================================
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.log
*.patch
*.diff
*.bin

# 범용 컴파일 산출물 (모든 하위 폴더의 모든 확장자 타겟)
**/*.slo
**/*.lo
**/*.o
**/*.obj
**/*.gch
**/*.pch
**/*.so
**/*.dylib
**/*.dll
**/*.lai
**/*.la
**/*.a
**/*.lib
**/*.exe
**/*.out
**/*.app
**/*.ipa
**/*.mod

# ==========================================
# 2. Server (C++ 서버 프로젝트 및 디버깅 파일)
# ==========================================
# MSBuild 디버깅 및 프로파일링 찌꺼기 파일 전체 차단
Server/**/*.pdb
Server/**/*.ilk
Server/**/*.idb
Server/**/*.tlog
Server/**/*.exp
Server/**/*.map
Server/**/*.db
Server/**/*.opendb

# 서버 빌드 출력 디렉토리 전체 차단 (JMServer 내부 포함)
Server/**/[Xx]64/
Server/**/[Xx]86/
Server/**/[Dd]ebug/
Server/**/[Rr]elease/

# ==========================================
# 3. UEClient (언리얼 엔진 프로젝트 'JM')
# ==========================================
# 언리얼 자동 생성 프로젝트 파일 무시 (최상위나 Server의 .sln은 안전하게 보호됨)
UEClient/**/*.sln
UEClient/**/*.xcodeproj
UEClient/**/*.xcworkspace
UEClient/**/*.opensdf
UEClient/**/*.sdf
UEClient/**/*.VC.db
UEClient/**/*.VC.opendb

# 사전 컴파일된 소스 아트 파일
UEClient/**/SourceArt/**/*.png
UEClient/**/SourceArt/**/*.tga

# 언리얼 엔진 임시, 바이너리, 캐시 폴더 전체 차단
UEClient/**/Binaries/
UEClient/**/Intermediate/
UEClient/**/Saved/
UEClient/**/DerivedDataCache/
UEClient/**/Build/
UEClient/**/Plugins/**/Binaries/
UEClient/**/Plugins/**/Intermediate/

# 언리얼 맵 빌트 데이터 및 에디터 내부 .vs 무시
*_BuiltData.uasset
UEClient/**/.vs/

# 언리얼 Build 폴더 내부의 필수 파일(아이콘, 블랙리스트) 화이트리스트 예외 처리
!UEClient/**/Build/
!UEClient/**/Build/*/
!UEClient/**/Build/*/PakBlacklist*.txt
!UEClient/**/Build/**/*.ico